<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7K Settings"
            android:textStyle="bold"
            android:textSize="20sp"
            android:paddingBottom="12dp" />

        <!-- Section: General -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_general"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swShowDock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Dock" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swShowSidebar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Sidebar" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swShowLabels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Labels" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swHideSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hide Search Box in Drawer" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSwipeClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Swipe-to-Close Drawer" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swPowerSaver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Launcher Power Saver" />

        <!-- General: Theme & Labels -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swDynamicColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dynamic_color" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/accent_color"
            android:paddingTop="12dp" />
        <Spinner
            android:id="@+id/spAccentColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/accent_color_names" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_lines"
            android:paddingTop="12dp" />
        <Spinner
            android:id="@+id/spLabelLines"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/label_lines_entries" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_font_size"
            android:paddingTop="12dp" />
        <Spinner
            android:id="@+id/spLabelFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/label_font_size_entries" />

        <!-- Section: App Drawer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_drawer"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drawer Columns"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbColumns"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tvColumnsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:paddingStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drawer_sort_order"
            android:paddingTop="12dp" />
        <Spinner
            android:id="@+id/spDrawerSortOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/drawer_sort_order_entries" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swDrawerAlphabetHeaders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_alphabet_headers"
            android:paddingTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Icon Size"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbIconSize"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tvIconSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:paddingStart="8dp" />
        </LinearLayout>

        <!-- Section: Dock -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_dock"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dock Icon Size"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbDockIconSize"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tvDockIconSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:paddingStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dock Length"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbDockLength"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tvDockLengthValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:paddingStart="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnManageDockApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Dock Apps" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dock Position"
            android:paddingTop="12dp" />
        <Spinner
            android:id="@+id/spDockPosition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/dock_position_entries" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dock_opacity"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbDockOpacity"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:max="100" />
            <TextView
                android:id="@+id/tvDockOpacityValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:paddingStart="8dp" />
        </LinearLayout>

        <!-- Section: Sidebar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_sidebar"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sidebar Icon Size"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbSidebarIconSize"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
                
            <TextView
                android:id="@+id/tvSidebarIconSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:paddingStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sidebar Length"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbSidebarLength"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tvSidebarLengthValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:paddingStart="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnManageSidebarApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Sidebar Apps" />

        <!-- Section: Home & Folders -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_home"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home Grid Columns"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbHomeColumns"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tvHomeColumnsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4"
                android:paddingStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Folder Grid Columns"
            android:paddingTop="12dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/sbFolderColumns"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tvFolderColumnsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4"
                android:paddingStart="8dp" />
        </LinearLayout>

        <!-- Clock toggle -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swShowClock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Clock on Home" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swPageDots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/page_indicator_dots" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swParallax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wallpaper_parallax" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swHomeLock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lock Home Layout (prevent edits)" />

        <!-- Competitive Features Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_advanced"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/btnIconPacks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Icon Packs"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnGestures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gesture Settings"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnPrivacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Privacy"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnBackup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create Backup"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnRestore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Restore Backup"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Search sources -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/search_sources"
            android:paddingTop="12dp" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSearchApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_apps" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSearchContacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_contacts" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSearchWeb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_web" />

        <!-- Hidden apps manager and auto-clear cache threshold -->
        <Button
            android:id="@+id/btnManageHiddenApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Hidden Apps"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto clear cache"
            android:paddingTop="12dp" />
        <Spinner
            android:id="@+id/spAutoClearCache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/auto_clear_cache_entries" />

        <!-- Section: Wallpaper -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_wallpaper"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btnWallpaperGallery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/choose_from_gallery"
                android:layout_marginEnd="4dp" />
            <Button
                android:id="@+id/btnWallpaperPreloaded"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/choose_preloaded"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Section: Storage -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_storage"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvStorageSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnClearCache"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/clear_cache"
                android:layout_marginEnd="4dp" />
            <Button
                android:id="@+id/btnClearWebData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/clear_web_data"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />
            <Button
                android:id="@+id/btnClearTemp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/clear_temp_files"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSystemMonitor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="System Monitor"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Done"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
