<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1115"
    android:padding="@dimen/studio_page_padding">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Photo Editor"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/studio_section_title_size"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Practical tools for fast edits"
        android:textColor="#9EA8B8"
        android:textSize="@dimen/studio_subtitle_size" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#171B24"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/previewImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:background="#11151D"
            android:contentDescription="Photo preview"
            android:scaleType="fitCenter" />
    </androidx.cardview.widget.CardView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/studio_glass_button_primary"
                android:contentDescription="Import photo from device"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Import"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnCrop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Crop photo"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Crop"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnRotate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Rotate photo"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Rotate"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnFlipH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Flip photo horizontally"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Flip H"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnFlipV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Flip photo vertically"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Flip V"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Open crop editor"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Edit"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Undo last edit"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Undo"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnRedo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Redo last undone edit"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Redo"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Reset photo adjustments"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Reset"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_teal"
                android:contentDescription="Save edited photo"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="#171B24"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:id="@+id/adjustmentsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adjustments"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/studio_body_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/studio_label_width"
                    android:layout_height="wrap_content"
                    android:text="Brightness"
                    android:textColor="#C7CFDA"
                    android:textSize="@dimen/studio_body_size" />

                <SeekBar
                    android:id="@+id/seekBrightness"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Brightness slider"
                    android:max="200"
                    android:progress="100" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/studio_label_width"
                    android:layout_height="wrap_content"
                    android:text="Contrast"
                    android:textColor="#C7CFDA"
                    android:textSize="@dimen/studio_body_size" />

                <SeekBar
                    android:id="@+id/seekContrast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Contrast slider"
                    android:max="200"
                    android:progress="100" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/studio_label_width"
                    android:layout_height="wrap_content"
                    android:text="Saturation"
                    android:textColor="#C7CFDA"
                    android:textSize="@dimen/studio_body_size" />

                <SeekBar
                    android:id="@+id/seekSaturation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Saturation slider"
                    android:max="200"
                    android:progress="100" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnFilterNone"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/studio_glass_button_secondary"
                        android:text="Reset"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnFilterWarm"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_button_secondary"
                        android:text="Warm"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnFilterCool"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_button_secondary"
                        android:text="Cool"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnFilterBW"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_button_secondary"
                        android:text="B&amp;W"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnFilterVivid"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_button_secondary"
                        android:text="Vivid"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnPresetCinematic"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_pill"
                        android:text="Cinematic"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnPresetPortrait"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_pill"
                        android:text="Portrait"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnPresetVibrant"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_pill"
                        android:text="Vibrant"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnPresetNight"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/studio_glass_pill"
                        android:text="Night"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
