<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1115"
    android:padding="@dimen/studio_page_padding">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Video Editor"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/studio_section_title_size"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Trim, speed, rotate, mute, frames, music replace"
        android:textColor="#9EA8B8"
        android:textSize="@dimen/studio_subtitle_size" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#171B24"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp">

        <VideoView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#11151D"
            android:contentDescription="Video preview player" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="@dimen/studio_label_width"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#C7CFDA"
            android:textSize="@dimen/studio_subtitle_size" />

        <SeekBar
            android:id="@+id/seekPreview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:contentDescription="Video timeline scrubber"
            android:max="1000"
            android:progress="0" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="@dimen/studio_label_width"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="00:00"
            android:textColor="#C7CFDA"
            android:textSize="@dimen/studio_subtitle_size" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPickVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/studio_glass_button_primary"
                android:contentDescription="Import video"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Import"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnPlayPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Play or pause video"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Play"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnTrim10s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Trim first ten seconds"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Trim 10s"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnRotate90"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Export rotated ninety degrees"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Rotate 90°"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnMuteExport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Export video without audio"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Mute Export"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnExtractFrame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Extract current frame as image"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="Extract Frame"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnSpeed05"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Export at half speed"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="0.5x"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnSpeed15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Export at one point five speed"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="1.5x"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnSpeed2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/studio_glass_button_secondary"
                android:contentDescription="Export at double speed"
                android:minHeight="@dimen/studio_button_min_height"
                android:minWidth="@dimen/studio_button_min_width"
                android:text="2x"
                android:textAllCaps="false" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="#171B24"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPickMusic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/studio_glass_button_secondary"
                    android:contentDescription="Pick replacement music"
                    android:minHeight="@dimen/studio_button_min_height"
                    android:minWidth="@dimen/studio_button_min_width"
                    android:text="Pick Music"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnExportWithMusic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/studio_glass_button_teal"
                    android:contentDescription="Export video with selected music"
                    android:minHeight="@dimen/studio_button_min_height"
                    android:minWidth="@dimen/studio_button_min_width"
                    android:text="Export + Music"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/studio_label_width"
                    android:layout_height="wrap_content"
                    android:text="Video Vol"
                    android:textColor="#C7CFDA"
                    android:textSize="@dimen/studio_subtitle_size" />

                <SeekBar
                    android:id="@+id/seekVolVideo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Video volume slider"
                    android:max="100"
                    android:progress="70" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/studio_label_width"
                    android:layout_height="wrap_content"
                    android:text="Music Vol"
                    android:textColor="#C7CFDA"
                    android:textSize="@dimen/studio_subtitle_size" />

                <SeekBar
                    android:id="@+id/seekVolMusic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Music volume slider"
                    android:max="100"
                    android:progress="70" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/labelStart"
                    android:layout_width="@dimen/studio_label_width"
                    android:layout_height="wrap_content"
                    android:text="Start: 0s"
                    android:textColor="#C7CFDA"
                    android:textSize="@dimen/studio_subtitle_size" />

                <SeekBar
                    android:id="@+id/seekStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Trim start slider"
                    android:max="1000"
                    android:progress="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/labelEnd"
                    android:layout_width="@dimen/studio_label_width"
                    android:layout_height="wrap_content"
                    android:text="End: 0s"
                    android:textColor="#C7CFDA"
                    android:textSize="@dimen/studio_subtitle_size" />

                <SeekBar
                    android:id="@+id/seekEnd"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Trim end slider"
                    android:max="1000"
                    android:progress="1000" />
            </LinearLayout>

            <Button
                android:id="@+id/btnExportTrimRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/studio_glass_button_primary"
                android:contentDescription="Export selected trim range"
                android:minHeight="@dimen/studio_button_min_height"
                android:text="Export Trim Range"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="No video selected"
        android:textColor="#9EA8B8"
        android:textSize="@dimen/studio_subtitle_size" />

</LinearLayout>
