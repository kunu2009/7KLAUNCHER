<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface"
    tools:context=".settings.EnhancedSettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Appearance Settings -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/appearanceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Theme Selection -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Theme"
                        android:textColor="?attr/colorOnSurface" />

                    <Spinner
                        android:id="@+id/themeSpinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="120dp" />

                </LinearLayout>

                <!-- Icon Size -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Icon Size"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="8dp" />

                    <SeekBar
                        android:id="@+id/iconSizeSeeker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="2"
                        android:progress="1" />

                </LinearLayout>

                <!-- Show Labels -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/showLabelsSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show app labels"
                    android:layout_marginBottom="16dp" />

                <!-- Glass Effect -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/glassEffectSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Glass effects (blur)"
                    android:layout_marginBottom="16dp" />

                <!-- Icon Pack Button -->
                <Button
                    android:id="@+id/iconPackButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select Icon Pack" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Home Screen Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Home Screen"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Grid Size -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Grid Size"
                        android:textColor="?attr/colorOnSurface" />

                    <Spinner
                        android:id="@+id/gridSizeSpinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="100dp" />

                </LinearLayout>

                <!-- Page Indicator -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/pageIndicatorSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show page indicator"
                    android:layout_marginBottom="16dp" />

                <!-- Infinite Scroll -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/infiniteScrollSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Infinite scroll" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- App Drawer Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="App Drawer"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Drawer Style -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Style"
                        android:textColor="?attr/colorOnSurface" />

                    <Spinner
                        android:id="@+id/drawerStyleSpinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="140dp" />

                </LinearLayout>

                <!-- Alphabetical Sort -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/alphabeticalSortSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sort alphabetically"
                    android:layout_marginBottom="16dp" />

                <!-- Search History -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/searchHistorySwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Remember search history"
                    android:layout_marginBottom="16dp" />

                <!-- App Suggestions -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/appSuggestionsSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show app suggestions" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Gesture Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gestures"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Gesture Settings Button -->
                <Button
                    android:id="@+id/gestureSettingsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Configure Gestures"
                    android:layout_marginBottom="16dp" />

                <!-- Haptic Feedback -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/hapticFeedbackSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Haptic feedback"
                    android:layout_marginBottom="16dp" />

                <!-- Gesture Sensitivity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gesture Sensitivity"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="8dp" />

                    <SeekBar
                        android:id="@+id/gestureSensitivitySeeker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="50" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Privacy Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Privacy &amp; Security"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Privacy Mode -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/privacyModeSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Privacy mode"
                    android:layout_marginBottom="16dp" />

                <!-- Hidden Apps -->
                <Button
                    android:id="@+id/hiddenAppsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manage Hidden Apps"
                    android:layout_marginBottom="8dp" />

                <!-- Locked Apps -->
                <Button
                    android:id="@+id/lockedAppsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manage Locked Apps"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/privacyCenterButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Open Privacy Center"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/lockTimeoutButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lock Timeout"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/authModeButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Authentication Mode"
                    android:layout_marginBottom="16dp" />

                <!-- Biometric Required -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/biometricRequiredSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Require biometric authentication" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Performance Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Performance"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Battery Optimization -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/batteryOptimizationSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Battery optimization"
                    android:layout_marginBottom="16dp" />

                <!-- Memory Optimization -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/memoryOptimizationSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Memory optimization"
                    android:layout_marginBottom="16dp" />

                <!-- Animation Scale -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Animation Scale"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="8dp" />

                    <SeekBar
                        android:id="@+id/animationScaleSeeker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="50" />

                </LinearLayout>

                <!-- Preload Apps -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/preloadAppsSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Preload frequently used apps" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Backup Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Backup &amp; Restore"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Export Button -->
                <Button
                    android:id="@+id/exportButton"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Export Backup"
                    android:layout_marginBottom="8dp" />

                <!-- Import Button -->
                <Button
                    android:id="@+id/importButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Import Backup"
                    android:layout_marginBottom="16dp" />

                <!-- Auto Backup -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/autoBackupSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Automatic backup"
                    android:layout_marginBottom="8dp" />

                <!-- Last Backup Text -->
                <TextView
                    android:id="@+id/lastBackupText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No backup found"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Advanced Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Advanced"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="16dp" />

                <!-- Debug Mode -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/debugModeSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Debug mode"
                    android:layout_marginBottom="16dp" />

                <!-- Reset Settings -->
                <Button
                    android:id="@+id/resetSettingsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reset All Settings"
                    android:textColor="?attr/colorError"
                    android:layout_marginBottom="8dp" />

                <!-- About Button -->
                <Button
                    android:id="@+id/aboutButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="About 7K Launcher" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>