<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="90" android:startColor="#00B4B4" android:endColor="#008A8A" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#88FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="90" android:startColor="#0CC0C0" android:endColor="#00A8A8" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#99B5FFFF" />
        </shape>
    </item>
</selector>
