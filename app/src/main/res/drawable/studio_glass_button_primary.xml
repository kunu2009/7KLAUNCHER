<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="90" android:startColor="#7B74FF" android:endColor="#5750DC" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#88FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="90" android:startColor="#8A84FF" android:endColor="#6A63FF" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#99D6D2FF" />
        </shape>
    </item>
</selector>
