<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.BIND_APPWIDGET" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.FLASHLIGHT" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    
    <!-- Queries for package visibility -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".SevenKApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SevenKLauncher"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:replace="android:label,android:theme">
        
        <!-- 7K Browser (Embedded App) -->
        <activity
            android:name="com.sevenk.browser.BrowserActivity"
            android:exported="true"
            android:label="7K Browser"
            android:icon="@mipmap/ic_launcher_browser"
            android:theme="@style/Theme.SevenK.Browser">
            <!-- Add MAIN/LAUNCHER intent filter so it appears in app drawer -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
            </intent-filter>
        </activity>

        <!-- 7K Launcher (Home Screen) -->
        <!-- Main Launcher (Home Screen) -->
        <activity
            android:name=".LauncherActivity"
            android:clearTaskOnLaunch="true"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="nosensor"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.SevenKLauncher"
            android:windowSoftInputMode="stateHidden|adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- 7K Settings (No Launcher) -->
        <activity
            android:name=".SettingsActivity"
            android:exported="true"
            android:label="7K Settings"
            android:icon="@drawable/ic_settings_7k">
        </activity>

        <!-- Enhanced Settings -->
        <activity
            android:name=".settings.EnhancedSettingsActivity"
            android:exported="false"
            android:label="Enhanced Settings"
            android:theme="@style/Theme.SevenKLauncher"
            android:parentActivityName=".LauncherActivity" />

        <!-- Expose a settings shortcut in the app drawer named 7KSettings -->
        <activity-alias
            android:name=".SettingsShortcut"
            android:exported="true"
            android:enabled="true"
            android:icon="@drawable/ic_settings_7k"
            android:label="7KSettings"
            android:targetActivity=".SettingsActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity-alias>

        <!-- Icon Pack Selection -->
        <activity
            android:name=".IconPackSelectionActivity"
            android:exported="false"
            android:label="Icon Packs"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- Gesture Settings -->
        <activity
            android:name=".GestureSettingsActivity"
            android:exported="false"
            android:label="Gestures"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- App Privacy Settings -->
        <activity
            android:name=".AppPrivacyActivity"
            android:exported="false"
            android:label="Privacy"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- System Monitor -->
        <activity
            android:name=".SystemMonitorActivity"
            android:exported="false"
            android:label="System Monitor"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- Study Activity -->
        <activity
            android:name=".StudyActivity"
            android:exported="false"
            android:label="7K Study"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- Global Search -->
        <activity
            android:name=".search.GlobalSearchActivity"
            android:exported="false"
            android:label="Search"
            android:theme="@style/Theme.SevenKLauncher" />

        <receiver
            android:name=".AppWidget"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/app_widget_info" />
        </receiver>

        <!-- TODO Widget -->
        <activity
            android:name=".TodoWidgetConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.SevenKLauncher" />

        <receiver
            android:name=".TodoWidgetProvider"
            android:exported="true"
            android:label="7K TODO">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/todo_widget_info" />
        </receiver>

        <service
            android:name=".TodoWidgetService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- Internal Photo Editor -->
        <activity
            android:name="com.sevenk.studio.StudioActivity"
            android:exported="false"
            android:label="7KSTUDIO"
            android:icon="@drawable/sevenk_studio_icon"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.studio.PhotoEditorActivity"
            android:exported="false"
            android:label="Photo Editor"
            android:icon="@drawable/sevenk_studio_icon"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.studio.VideoEditorActivity"
            android:exported="false"
            android:label="Video Editor"
            android:icon="@drawable/sevenk_studio_icon"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- Internal Web App wrapper -->
        <activity
            android:name=".WebAppActivity"
            android:exported="false"
            android:label="Web App"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- 7K Notes (Native) -->
        <activity
            android:name="com.sevenk.launcher.notes.ui.NotesActivity"
            android:exported="false"
            android:label="@string/notes_title"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.notes.ui.NoteEditorActivity"
            android:exported="false"
            android:label="@string/note_editor_title"
            android:theme="@style/Theme.SevenKLauncher" />

        <!-- 7K Native Ecosystem Apps -->
        <activity
            android:name="com.sevenk.launcher.ecosystem.UtilityActivity"
            android:exported="false"
            android:label="7K Utility"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.GamesActivity"
            android:exported="false"
            android:label="7K Games"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.WidgetsHubActivity"
            android:exported="false"
            android:label="7K Widgets"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.AppStoreActivity"
            android:exported="false"
            android:label="7K AppStore"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.TasksCommanderActivity"
            android:exported="false"
            android:label="7K Tasks Commander"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.FileForgeActivity"
            android:exported="false"
            android:label="7K File Forge"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.BudgetGuardianActivity"
            android:exported="false"
            android:label="7K Budget Guardian"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.PrivacyShieldActivity"
            android:exported="false"
            android:label="7K Privacy Shield"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.BatteryDoctorActivity"
            android:exported="false"
            android:label="7K Battery Doctor"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.StudioTemplatesActivity"
            android:exported="false"
            android:label="7K Studio Templates"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.OfflineFirstAppStoreActivity"
            android:exported="false"
            android:label="7K Offline First AppStore"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.CalendarActivity"
            android:exported="false"
            android:label="7K Calendar"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.MusicActivity"
            android:exported="false"
            android:label="7K Music"
            android:theme="@style/Theme.SevenKLauncher" />
        <activity
            android:name="com.sevenk.launcher.ecosystem.WeatherActivity"
            android:exported="false"
            android:label="7K Weather"
            android:theme="@style/Theme.SevenKLauncher" />
        <!-- Add FileProvider for file sharing if needed -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- uCrop activity (image cropper) -->
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

    </application>
</manifest>
